# ──────────────────────────────────────────────────────────────────────────
# REQUIRED for the studio pipeline (script → image → voice → MP4)
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# REQUIRED for accounts + saving videos to the library
# Set ALL FOUR or leave them ALL blank (anonymous mode still works).
# ──────────────────────────────────────────────────────────────────────────
# Postgres URL (Vercel Postgres → "Storage" tab is the easiest).
DATABASE_URL=

# Random 32-byte secret. Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorised redirect URIs (add both):
#   http://localhost:3000/api/auth/callback/google
#   https://YOUR-VERCEL-DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# REQUIRED for storing finished MP4s + images
# Enable Vercel Blob in your project → "Storage" tab → Create new Blob store.
# Vercel will auto-inject this for you. For local dev, copy from the dashboard.
# ──────────────────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# OPTIONAL — premium voice
# Toggle the voice provider to "ElevenLabs" in /studio once this is set.
# ──────────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ──────────────────────────────────────────────────────────────────────────
# OPTIONAL — cheaper images at scale (~$0.003/img vs OpenAI low ~$0.011/img)
# ──────────────────────────────────────────────────────────────────────────
REPLICATE_API_TOKEN=
FAL_KEY=
