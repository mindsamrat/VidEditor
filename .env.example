# ─── REQUIRED RIGHT NOW ──────────────────────────────────────────────────
# These two keys make the entire /studio pipeline work end-to-end:
#   script (Claude) → images (OpenAI) → voice (OpenAI TTS) → MP4 (in-browser).
#
# Add them in Vercel: Project → Settings → Environment Variables → Production.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── OPTIONAL — better voice ─────────────────────────────────────────────
# Set this and toggle the Studio voice dropdown to "ElevenLabs" for premium
# narrator quality (~10× more expensive than OpenAI TTS).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── OPTIONAL — cheaper images at scale ──────────────────────────────────
# When per-image cost matters, swap /api/generate/image to Replicate Flux
# Schnell (~$0.003/image vs OpenAI low at ~$0.011).
REPLICATE_API_TOKEN=
FAL_KEY=

# ─── OPTIONAL — auth (when you wire login) ───────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OPTIONAL — persistence (when you save series + library) ─────────────
DATABASE_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── OPTIONAL — auto-posting (later) ─────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
