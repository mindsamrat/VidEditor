# ─── REQUIRED for /studio playground ─────────────────────────────────────
# Add these in Vercel: Project → Settings → Environment Variables
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# Optional: override the default ElevenLabs voice ("Rachel" - 21m00Tcm4TlvDq8ikWAM)
ELEVENLABS_VOICE_ID=

# ─── OPTIONAL (later) ────────────────────────────────────────────────────
# Auth — only needed when you wire login. Currently the app is open.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database — only needed when you persist series + videos
DATABASE_URL=

# Cheaper image gen alternative (instead of OpenAI)
REPLICATE_API_TOKEN=
FAL_KEY=

# Storage — when you start saving generated assets
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Job queue + scheduler (for auto-posting)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Social posting
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
